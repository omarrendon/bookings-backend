# ── BASE DE DATOS ─────────────────────────────────────────────────────────────
DB_USER=postgres
DB_NAME=reservas_db
DB_PASSWORD=yourpassword
DB_HOST=localhost        # En Docker usa "db" (nombre del servicio en docker-compose)
DB_PORT=5432

# ── SERVIDOR ──────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development     # "development" | "production"

# ── ZONA HORARIA ──────────────────────────────────────────────────────────────
DB_TIMEZONE=00:00                  # Zona horaria para Sequelize (UTC recomendado)
TIMEZONE=America/Mexico_City       # Zona horaria para cálculo de slots

# ── AUTENTICACIÓN ─────────────────────────────────────────────────────────────
# Genera una clave segura con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_jwt_secret_key_min_32_chars

# ── EMAIL ─────────────────────────────────────────────────────────────────────
EMAIL_PROVIDER=resend              # Proveedor de email (por ahora solo "resend")
RESEND_API_KEY=re_xxxxxxxxxxxx     # API key de https://resend.com
EMAIL_FROM=noreply@tudominio.com   # Dirección remitente verificada en Resend

# URL base del backend, usada en los links de los emails (ej. reset de contraseña)
HOST=http://localhost:3000

# ── STORAGE DE IMÁGENES ───────────────────────────────────────────────────────
STORAGE_PROVIDER=cloudinary            # Proveedor activo: "cloudinary" (o el que agregues)
CLOUDINARY_CLOUD_NAME=your_cloud_name  # Dashboard de Cloudinary → Settings → Account
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── FRONTEND ──────────────────────────────────────────────────────────────────
DEVELOPMENT_FRONTEND_URL=http://localhost:5173
CORS_ORIGIN=http://localhost:5173  # Origen permitido para CORS
